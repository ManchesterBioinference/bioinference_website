@techreport{d031ae09abad4321a2dc0dd7001f404e,
 abstract = {Chinese hamster ovary (CHO) cells are the industrial workhorse for manufacturing biopharmaceuticals, including monoclonal antibodies. CHO cell line development requires a more data-driven approach for the accelerated identification of hyper-productive cell lines. Traditional methods, which rely on time-consuming hierarchical screening, often fail to elucidate the underlying cellular mechanisms driving optimal bioreactor performance. Big data analytics, coupled with advancements in \textquoteleftomics\textquoteright technologies, are revolutionizing the study of industrial cell lines. However, translating this knowledge into practical methods widely utilized in industrial biomanufacturing remains a significant challenge. This study leverages discovery proteomics to characterize dynamic changes within the CHO cell proteome during a 14 day fed-batch bioreactor cultivation. Utilizing a global untargeted proteomics workflow, we identify 3358 proteins, using a ZenoTOF 7600 and a Cyclic IMS QToF. By mapping relative abundances to key cellular processes, eight protein targets were selected as potential biomarkers. To bridge the gap between discovery and industrial applications, we translated these findings into a rapid 15 minute targeted triple quadrupole (MRM) assay. This approach demonstrates the potential of repurposing discovery proteomics for targeted biomarker identification in biotherapeutic production. By monitoring these biomarkers we can potentially streamline the screening of biomanufacturing cell lines and culture conditions, ultimately accelerating biotherapeutic development.},
 address = {United States},
 author = {Charles Eldrid and Ellie Hawke and Cain, \Kathleen M.\ and Kate Meeson and Joanne Watson and Reynard Spiess and William Smith and Matthew Russell and Robyn Hoare and John Raven and Jean-Marc Schwartz and Magnus Rattray and Leon Pybus and Alan Dickson and Andrew Pitt and Perdita Barran},
 day = {19},
 doi = {10.26434/chemrxiv-2024-0qc8t},
 institution = {ChemRxiv},
 language = {English},
 month = {November},
 pages = {1--17},
 publisher = {ChemRxiv},
 title = {From Discovery to Delivery: A Rapid and Targeted Proteomics Workflow for Monitoring Chinese Hamster Ovary Biomanufacturing},
 type = {WorkingPaper},
 year = {2024}
}

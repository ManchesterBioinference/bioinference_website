@article{29ca185ea19f4323b150d40cd35c6c34,
 abstract = {Zinc is essential for life, but toxic in excess. Thus all cells must control their internal zinc concentration. We used a systems approach, alternating rounds of experiments and models, to further elucidate the zinc control systems in Escherichia coli. We measured the response to zinc of the main specific zinc import and export systems in the wild-type, and a series of deletion mutant strains. We interpreted these data with a detailed mathematical model and Bayesian model fitting routines. There are three key findings: first, that alternate, non-inducible importers and exporters are important. Second, that an internal zinc reservoir is essential for maintaining the internal zinc concentration. Third, our data fitting led us to propose that the cells mount a heterogeneous response to zinc: some respond effectively, while others die or stop growing. In a further round of experiments, we demonstrated lower viable cell counts in the mutant strain tested exposed to excess zinc, consistent with this hypothesis. A stochastic model simulation demonstrated considerable fluctuations in the cellular levels of the ZntA exporter protein, reinforcing this proposal. We hypothesize that maintaining population heterogeneity could be a bet-hedging response allowing a population of cells to survive in varied and fluctuating environments.},
 author = {Hiroki Takahashi and Taku Oshima and Hobman, \Jon L.\ and Neil Doherty and Clayton, \Selina R.\ and Mudassar Iqbal and Hill, \Philip J.\ and Toru Tobe and Naotake Ogasawara and Shigehiko Kanaya and Stekel, \Dov J.\},
 issn = {1742-5689},
 journal = {Journal of the Royal Society Interface},
 language = {English},
 number = {106},
 pages = {1--12},
 publisher = {The Royal Society Publishing},
 title = {The dynamic balance of import and export of zinc in Escherichia coli suggests a heterogeneous population response to stress},
 volume = {12},
 year = {2015}
}
